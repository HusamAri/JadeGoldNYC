# ------------------------------------------------------------------
# Jade Gold NYC — Yönetim Paneli ortam değişkenleri
# Bu dosyayı `.env.local` olarak kopyalayın ve değerleri doldurun.
# ------------------------------------------------------------------

# Supabase (proje oluşturulduktan sonra doldurulur)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=            # yalnız sunucu tarafı: sync, callback, RPC

# Uygulama
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Etsy Open API v3 (developers.etsy.com'da uygulama kaydı sonrası)
ETSY_API_KEY=                         # keystring -> x-api-key header
ETSY_API_SECRET=                      # shared secret
ETSY_OAUTH_REDIRECT_URI=http://localhost:3000/api/etsy/callback
ETSY_SCOPES=transactions_r listings_r email_r

# Cron koruması (Vercel Cron -> /api/cron/etsy-sync)
CRON_SECRET=

# AI (Vercel AI Gateway) — bkz. docs/ai-gateway.md
# Local geliştirme için anahtar; Vercel'de VERCEL_OIDC_TOKEN otomatik gelir (gerekmez).
AI_GATEWAY_API_KEY=
AI_MODEL=anthropic/claude-sonnet-4.6   # opsiyonel: varsayılan modeli değiştir
